                                        <div class="form-check mb-2">
                                            <input class="form-check-input" type="checkbox" name="pacientes-CUD[]" value="Si" id="Si-pacientes-CUD">
                                            <label class="form-check-label" for="Si-pacientes-CUD" style="font-size: 14px;"> Si </label>
                                        </div>
                                        <div class="form-check mb-2">
                                            <input class="form-check-input" type="checkbox" name="pacientes-CUD[]" value="No" id="No-pacientes-CUD">
                                            <label class="form-check-label" for="No-pacientes-CUD" style="font-size: 14px;"> No </label>
