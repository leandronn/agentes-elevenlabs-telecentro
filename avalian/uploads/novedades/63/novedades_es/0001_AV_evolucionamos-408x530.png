<script>
    document.addEventListener('DOMContentLoaded', function () {
        
        var selectTipo = document.getElementById('contactoTipo');
        var textoInformativo = document.getElementById('textoInformativo');
        var campos_quiero_ser_prestador = document.getElementById('campos-quiero-ser-prestador');
        var postulacion_prestador_text = document.getElementById('postulacion-prestador-text');

        function actualizarTexto() {
            if (selectTipo.value === 'QUIERO_SER_PRESTADOR') {
                textoInformativo.textContent = 'Para formar parte de nuestra red de profesionales completa el formulario';
            } else {
                textoInformativo.textContent = 'Completá los siguientes datos';
            }
        }

        function actualizarVisibilidad() {
            if (selectTipo.value === 'QUIERO_SER_PRESTADOR') {
                campos_quiero_ser_prestador.style.display = 'block';
                postulacion_prestador_text.style.display = 'block';
            } else {
                campos_quiero_ser_prestador.style.display = 'none';
                postulacion_prestador_text.style.display = 'none';
            }
        }

        selectTipo.addEventListener('change', function () {
            actualizarTexto();
            actualizarVisibilidad();
        });

        // Dejo que solo se seleccione un checkbox para el campo de si pertenece a sociedades/asociaciones
        function initializeCheckboxes(containerId) {
            var checkboxes = document.querySelectorAll(containerId + ' .form-check-input');
            checkboxes.forEach(function(checkbox) {
                checkbox.addEventListener('change', function() {
                    if (this.checked) {
                        checkboxes.forEach(function(otherCheckbox) {
                            if (otherCheckbox !== checkbox) {
                                otherCheckbox.checked = false;
                            }
                        });
                    }
                });
            });
        }

        initializeCheckboxes('#sociedades-asociaciones-container');
        initializeCheckboxes('#institucion-pacientes-CUD');
        actualizarTexto();
        actualizarVisibilidad();
    });
</script>

